pipeline {
    agent any
    stages{
        stage('PULL'){
            steps{
                git branch: 'main', url: ' https://github.com/srushtilohakare111-hue/cdec-b48-terraform '
            }
        }
        stage('PLAN'){
            steps{
                sh'''
                cd infra/radison-hms-infra

                terraform init -reconfigure
                terraform plan --var-file=vars/staging.tfvars
                '''
            }
        }
        stage('APPROVAL'){
            steps{
                input 'Wait for approval'
            }
        }
        stage('APPLY'){
            steps{
                sh'''
                cd infra/radison-hms-infra
                terraform init -reconfigure
                terraform apply -auto-approve --var-file=vars/staging.tfvars
                '''
            }
        }
    }
}